# Credenciales S3 para la pantalla Ajustes (y código que use loadAWSConfig).
# Prefijo VITE_ obligatorio para que Vite las incluya en el cliente.

VITE_S3_BUCKET=tu-bucket-s3
VITE_AWS_ACCESS_KEY_ID=tu-access-key-id
VITE_AWS_SECRET_ACCESS_KEY=tu-secret-access-key

# Opcional: prefijo de rutas S3 legado (por defecto `public`).
# VITE_S3_ROOT_PREFIX=public

# API HTTP de administración (Lambda datadroneuser en AWS) — ver WORKFLOW_SETUP.md
#
# --- Producción (Amplify Hosting) — obligatorio en Console → Environment variables ---
# VITE_WORKFLOW_API_URL=https://your-api.execute-api.us-east-1.amazonaws.com
# No uses /workflow-api ni VITE_WORKFLOW_API_PROXY_TARGET en Amplify (solo existen en npm run dev).
#
# --- Desarrollo local (opcional: proxy Vite evita CORS) ---
# VITE_WORKFLOW_API_URL=/workflow-api
# VITE_WORKFLOW_API_PROXY_TARGET=https://your-api.execute-api.us-east-1.amazonaws.com
#
# --- Desarrollo local (directo a API Gateway, requiere CORS con localhost:5173) ---
# VITE_WORKFLOW_API_URL=https://your-api.execute-api.us-east-1.amazonaws.com
