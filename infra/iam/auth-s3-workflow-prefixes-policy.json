{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "ListBucketByPrefix",
      "Effect": "Allow",
      "Action": ["s3:ListBucket", "s3:GetBucketLocation"],
      "Resource": "arn:aws:s3:::ts-oraculo-drones-data1d195-dev",
      "Condition": {
        "StringLike": {
          "s3:prefix": [
            "public/",
            "public/*"
          ]
        }
      }
    },
    {
      "Sid": "ObjectAccessByPrefix",
      "Effect": "Allow",
      "Action": [
        "s3:GetObject",
        "s3:PutObject",
        "s3:DeleteObject",
        "s3:AbortMultipartUpload",
        "s3:ListMultipartUploadParts"
      ],
      "Resource": "arn:aws:s3:::ts-oraculo-drones-data1d195-dev/public/*"
    }
  ]
}
